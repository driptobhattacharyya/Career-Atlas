# ── FastAPI ──────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# ── Supabase (Dashboard → Project Settings → API) ────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SECRET_KEY=sb_secret_your_key_here

# ── Auth ─────────────────────────────────────────────────
# true  → skip JWT verification, run every request as DEV_USER_ID
# false → require a real Supabase (Google) login
DEV_BYPASS_AUTH=false
DEV_USER_ID=00000000-0000-0000-0000-000000000001

# ── LLMs ─────────────────────────────────────────────────
# Groq powers resume parsing, gap analysis, roadmap/deep research, and the judge.
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile
# Gemini is used only for embeddings (Pinecone semantic retrieval). Support rotation with _1, _2, etc.
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE
GOOGLE_API_KEY_1=
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=
GOOGLE_API_KEY_4=

# ── Web search ───────────────────────────────────────────
TAVILY_API_KEY=YOUR_TAVILY_API_KEY_HERE

# ── Gap analysis: Pinecone vector search + Jina rerank ───
JINA_API_KEY=YOUR_JINA_API_KEY_HERE
PINECONE_API_KEY=YOUR_PINECONE_API_KEY_HERE
PINECONE_INDEX_NAME=careeratlas
PINECONE_REGION=us-east-1
PINECONE_HOST=YOUR_PINECONE_HOST_URL_HERE

# ── Job search: Adzuna ───────────────────────────────────
ADZUNA_APP_ID=YOUR_ADZUNA_APP_ID
ADZUNA_APP_KEY=YOUR_ADZUNA_APP_KEY

# ── Monitoring ───────────────────────────────────────────
# Sentry error tracking — leave blank to disable.
SENTRY_DSN=
# LangSmith LLM/agent tracing.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=YOUR_LANGSMITH_API_KEY
LANGSMITH_PROJECT=careeratlas-prod

# GitHub OAuth App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
