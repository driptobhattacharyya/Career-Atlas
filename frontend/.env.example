# Backend API base — must point to the running FastAPI service.
VITE_API_BASE_URL=http://localhost:8000

# Supabase project (must match the backend's SUPABASE_URL).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Optional: dev parity with backend DEV_BYPASS_AUTH. Skips Google OAuth flow,
# uses VITE_DEV_USER_ID as the seeded auth.users id.
VITE_DISABLE_AUTH=false
VITE_DEV_USER_ID=
