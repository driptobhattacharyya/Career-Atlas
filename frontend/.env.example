# Backend API base — must point to the running FastAPI service.
VITE_API_BASE_URL=http://localhost:8000

# Supabase project (must match the backend's SUPABASE_URL).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Auth — keep in sync with the backend.
#   true  → skip Google sign-in, run as VITE_DEV_USER_ID
#   false → real Google OAuth (matches backend DEV_BYPASS_AUTH=false)
VITE_DISABLE_AUTH=false
VITE_DEV_USER_ID=00000000-0000-0000-0000-000000000001

# Sentry browser error tracking — leave blank to disable.
VITE_SENTRY_DSN=
